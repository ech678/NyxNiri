root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.kdl]
indent_size = 4

[*.toml]
indent_size = 4

[*.fish]
indent_size = 4

[*.lua]
indent_size = 4

[*.py]
indent_size = 4

[*.sh]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
