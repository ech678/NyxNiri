// 该配置文件采用 KDL 格式：https://kdl.dev
// "/-" 用于注释掉其后的节点。
// 请查阅 wiki 获取完整的配置说明：
// https://github.com/YaLTeR/niri/wiki/Configuration:-Introduction
config-notification {
    disable-failed
}

gestures {
    hot-corners {
        off
    }
}

// 输入设备配置。
// 在 wiki 上查找完整的选项列表：
// https://github.com/YaLTeR/niri/wiki/Configuration:-Input
input {
    keyboard {
        xkb {
            // 你可以设置 rules, model, layout, variant 和 options。
            // 更多信息请参阅 xkeyboard-config(7)。

            // 例如：
            // layout "us,ru"
            // options "grp:win_space_toggle,compose:ralt,ctrl:nocaps"

            // 如果此部分留空，niri 将从 org.freedesktop.locale1 获取 xkb 设置。
            // 你可以使用 localectl set-x11-keymap 控制这些设置。
        }

        // 启动时启用数字键盘锁定，省略此设置将其禁用。
        numlock
    }

    // 以下部分包含 libinput 设置。
    // 省略设置将禁用它们，或使其保持默认值。
    // 此处所有注释掉的设置均为示例，而非默认值。
    touchpad {
        // off
        tap
        // dwt
        // dwtp
        // drag false
        // drag-lock
        natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "two-finger"
        // disabled-on-external-mouse
    }

    mouse {
        // natural-scroll
        accel-speed -0.72
        // accel-profile "adaptive"
        // scroll-method "no-scroll"
    }

    trackpoint {
        // off
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-method "on-button-down"
        // scroll-button 273
        // scroll-button-lock
        // middle-emulation
    }

    // 取消注释此行，使鼠标移动到新聚焦窗口的中心。
    // warp-mouse-to-focus

    // 鼠标移入时自动聚焦窗口和输出设备。
    // 设置 max-scroll-amount="0%" 使其仅在完全位于屏幕上的窗口起作用。
    // focus-follows-mouse max-scroll-amount="0%"
}

// 你可以通过名称配置输出设备，在 niri 实例中运行 `niri msg outputs` 可以找到设备名称。
// 笔记本内置显示器通常称为 "eDP-1"。
// 在 wiki 上查找更多信息：
// https://github.com/YaLTeR/niri/wiki/Configuration:-Outputs
// 记得删除 "/-" 来取消注释该节点！
/-output "eDP-2" {
    mode "2560x1600@239.998993"
    position x=2560 y=0
    variable-refresh-rate
}

// 影响窗口位置和大小的设置。
// 更多信息请参阅 wiki：
// https://github.com/YaLTeR/niri/wiki/Configuration:-Layout
layout {
    // 设置逻辑像素中窗口周围的间隙。
    background-color "transparent"
    
    // 切换焦点时何时居中一列，选项为：
    // - "never", 默认行为，聚焦屏幕外的列将使其保持在屏幕的左侧或右侧边缘。
    // - "always", 聚焦的列将始终居中。
    // - "on-overflow", 如果聚焦的列与之前聚焦的列无法一起容纳，则会将其居中。
    center-focused-column "never"
    
    // 你可以自定义 "switch-preset-column-width" (Mod+Space) 切换的宽度。
    preset-column-widths {
        // proportion 将宽度设置为输出宽度的比例，并考虑间隙。
        // 例如，你可以在一个屏幕上完美放置四个大小为 "proportion 0.25" 的窗口。
        // 默认预设宽度为输出的 1/3、1/2 和 2/3。
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        // fixed 精确设置逻辑像素中的宽度。
        // fixed 1920
    }
    
    // 你也可以自定义 "switch-preset-window-height" (Mod+Shift+R) 切换的高度。
    // preset-window-heights { }
    
    // 你可以更改新窗口的默认宽度。
    default-column-width { proportion 0.5; }
    
    // 如果你让括号为空，窗口将自行决定其初始宽度。
    // default-column-width {}
    
    // 默认情况下，焦点环和边框在窗口后面渲染为纯背景矩形。
    // 这意味着它们会透过半透明窗口显示出来。
    // 这是因为使用客户端装饰的窗口可以有任意形状。
    //
    // 如果你不喜欢这样，应该取消注释下面的 `prefer-no-csd`。
    // Niri 将在同意省略其客户端装饰的窗口 *周围* 绘制焦点环和边框。
    //
    // 或者，你可以使用名为 `draw-border-with-background` 的窗口规则来覆盖它。
    border {
        off
        width 4
        active-color   "#707070"      // 中性灰
        inactive-color "#d0d0d0"      // 浅灰
        urgent-color   "#cc4444"      // 柔和红
    }
    
    shadow {
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    
    struts {
    }
}

// === 全局背景模糊配置 (Blur) 必须放在外层 ===
blur {
    // 渲染迭代次数，数值越高模糊越平滑，但性能开销略大（默认是 3）
    passes 3
    // 每次迭代的采样偏移距离，增大可增强模糊但过大可能有伪影（默认 3.0）
    offset 3.0
    // 添加的噪点强度，有助于减少色彩带（默认 0.02）
    noise 0.02
    // 模糊背景的饱和度倍数（默认 1.5）
    saturation 1.2
}

/* // --- 备用的新模糊与全局窗口规则效果（作为注释保留） ---
// blur {
//     passes 2
//     offset 3.0
//     noise 0.02
//     saturation 1.4
